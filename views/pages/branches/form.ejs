<div class="page-header">
  <div>
    <h2><%= branch ? 'Editar sede' : 'Nueva sede' %></h2>
    <p><%= branch ? 'Modificá los datos de la sede' : 'Completá los datos para crear una sede' %></p>
  </div>
  <a href="/branches" class="btn btn-secondary">← Volver</a>
</div>

<div class="card">
  <div class="card-body">
    <form action="<%= branch ? '/branches/' + branch.id + '/edit' : '/branches/new' %>" method="POST">
      <div class="form-grid">
        <div class="form-group">
          <label for="name">Nombre</label>
          <input type="text" id="name" name="name" value="<%= branch ? branch.name : '' %>" required>
        </div>
        <div class="form-group">
          <label for="country">País</label>
          <input type="text" id="country" name="country" value="<%= branch ? branch.country : '' %>" required>
        </div>
        <div class="form-group">
          <label for="city">Ciudad</label>
          <input type="text" id="city" name="city" value="<%= branch ? branch.city : '' %>" required>
        </div>
        <div class="form-group">
          <label for="address">Dirección</label>
          <input type="text" id="address" name="address" value="<%= branch ? branch.address : '' %>" required>
        </div>
      </div>
      <div style="margin-top: 20px; display: flex; gap: 10px;">
        <button type="submit" class="btn btn-primary"><%= branch ? 'Guardar cambios' : 'Crear sede' %></button>
        <a href="/branches" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
