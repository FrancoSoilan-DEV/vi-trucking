<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — VI-Trucking</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="login-page">
    <div class="login-card">
      <div class="login-logo">
        <h1>VI-<span>Trucking</span></h1>
        <p>Sistema de logística y transporte</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="flash flash-error">❌ <%= error %></div>
      <% } %>

      <form action="/auth/login" method="POST">
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="admin@vitrucking.com" required>
        </div>
        <div class="form-group">
          <label for="password">Contraseña</label>
          <input type="password" id="password" name="password" placeholder="••••••••" required>
        </div>
        <button type="submit" class="btn btn-primary login-btn">Iniciar sesión</button>
      </form>
    </div>
  </div>
</body>
</html>
