<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'VI-Trucking' %> — VI-Trucking</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="sidebar-logo">
        <h1>VI-<span>Trucking</span></h1>
        <p>Sistema de logística</p>
      </div>
      <nav class="sidebar-nav">
        <div class="nav-section">
          <div class="nav-section-title">General</div>
          <a href="/dashboard" class="nav-item <%= typeof page !== 'undefined' && page === 'dashboard' ? 'active' : '' %>">
            <span class="icon">📊</span> Dashboard
          </a>
        </div>
        <div class="nav-section">
          <div class="nav-section-title">Gestión</div>
          <% if (typeof user !== 'undefined' && user && (user.role === 'SUPERADMIN' || user.role === 'ADMIN')) { %>
          <a href="/users" class="nav-item <%= typeof page !== 'undefined' && page === 'users' ? 'active' : '' %>">
            <span class="icon">👥</span> Usuarios
          </a>
          <a href="/branches" class="nav-item <%= typeof page !== 'undefined' && page === 'branches' ? 'active' : '' %>">
            <span class="icon">🏢</span> Sedes
          </a>
          <a href="/drivers" class="nav-item <%= typeof page !== 'undefined' && page === 'drivers' ? 'active' : '' %>">
            <span class="icon">🧑‍✈️</span> Conductores
          </a>
          <a href="/vehicles" class="nav-item <%= typeof page !== 'undefined' && page === 'vehicles' ? 'active' : '' %>">
            <span class="icon">🚛</span> Vehículos
          </a>
          <a href="/clients" class="nav-item <%= typeof page !== 'undefined' && page === 'clients' ? 'active' : '' %>">
            <span class="icon">🏭</span> Clientes
          </a>
          <% } %>
        </div>
        <div class="nav-section">
          <div class="nav-section-title">Operaciones</div>
          <a href="/trips" class="nav-item <%= typeof page !== 'undefined' && page === 'trips' ? 'active' : '' %>">
            <span class="icon">🗺️</span> Viajes
          </a>
          <% if (typeof user !== 'undefined' && user && user.role === 'SUPERADMIN') { %>
          <a href="/tariffs" class="nav-item <%= typeof page !== 'undefined' && page === 'tariffs' ? 'active' : '' %>">
            <span class="icon">💰</span> Tarifas
          </a>
          <% } %>
        </div>
      </nav>
      <div class="sidebar-footer">
        <div class="user-info">
          <div class="user-avatar"><%= typeof user !== 'undefined' && user ? user.name.charAt(0).toUpperCase() : 'U' %></div>
          <div>
            <div class="user-name"><%= typeof user !== 'undefined' && user ? user.name : '' %></div>
            <div class="user-role"><%= typeof user !== 'undefined' && user ? user.role : '' %></div>
          </div>
        </div>
        <a href="/auth/logout" class="logout-btn">🚪 Cerrar sesión</a>
      </div>
    </aside>
    <main class="main">
      <div class="topbar">
        <div class="topbar-title"><%= typeof title !== 'undefined' ? title : '' %></div>
        <div class="topbar-right">
          <span style="color: var(--text-muted); font-size: 13px;">
            <%= new Date().toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
          </span>
        </div>
      </div>
      <div class="content">
        <% if (typeof success !== 'undefined' && success) { %>
          <div class="flash flash-success">✅ <%= success %></div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="flash flash-error">❌ <%= error %></div>
        <% } %>
        <%- body %>
      </div>
    </main>
  </div>
</body>
</html>